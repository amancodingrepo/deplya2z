# ─── Server ──────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── Database (Neon PostgreSQL) ───────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/store_warehouse
# Production Neon example:
# DATABASE_URL=postgresql://<user>:<password>@<endpoint>.neon.tech/<db>?sslmode=require
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000
DB_SSL_REJECT_UNAUTHORIZED=false

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ─── BCrypt ──────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── Cloudflare R2 ───────────────────────────────────────────
CF_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=store-warehouse-images
R2_PUBLIC_URL=https://pub-your-bucket-hash.r2.dev

# ─── Image Processing ────────────────────────────────────────
IMAGE_MAX_INPUT_SIZE_MB=5
IMAGE_FULL_WIDTH=800
IMAGE_FULL_HEIGHT=800
IMAGE_FULL_QUALITY=80
IMAGE_THUMB_WIDTH=300
IMAGE_THUMB_HEIGHT=300
IMAGE_THUMB_QUALITY=70

# ─── Pagination ──────────────────────────────────────────────
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=100

# ─── Inventory ───────────────────────────────────────────────
DEFAULT_LOW_STOCK_THRESHOLD=10

# ─── Redis / Upstash (for Bull queue) ───────────────────────
# Local Redis:
# REDIS_URL=redis://localhost:6379
# Upstash (TLS required — use the rediss:// TCP URL from the Connect tab):
REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379

# ─── Email / Resend ──────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# From address must be a domain you've verified in Resend
RESEND_FROM=noreply@yourdomain.com

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
