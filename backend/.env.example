# Server Configuration
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Database Configuration (PostgreSQL/Neon)
# Local PostgreSQL:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/store_warehouse
# Neon PostgreSQL (recommended for prod):
# DATABASE_URL=postgresql://<user>:<password>@<endpoint>.neon.tech/<db>?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/store_warehouse
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000
DB_SSL_REJECT_UNAUTHORIZED=false

# JWT Configuration
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=24h

# Bcrypt Configuration
BCRYPT_ROUNDS=12

# Redis Configuration (for Bull queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration
SESSION_TIMEOUT_MINUTES=30

# Notification Configuration (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@storewarehouse.com

# Push Notification Configuration (optional)
FIREBASE_SERVICE_ACCOUNT_PATH=

# Feature Flags
ENABLE_AUDIT_LOGGING=true
ENABLE_NOTIFICATIONS=true
ENABLE_RATE_LIMITING=true
